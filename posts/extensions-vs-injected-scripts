<script>

// ---- PAGE LOGIC ----
let counter = 0;

function pageAction() {
    counter++;

    document.getElementById("counter").innerText =
        "Counter: " + counter;

    document.getElementById("log").innerText =
        "Log: original page logic executed.";
}

// ---- EXTENSION (UI ONLY) ----
function runExtension() {
    document.body.style.border = "3px solid #facc15";

    document.getElementById("mode").innerText =
        "Mode: EXTENSION ACTIVE (UI only)";

    document.getElementById("log").innerText =
        "Extension modified only the DOM appearance.";
}

// ---- INJECTED SCRIPT (LOGIC OVERRIDE) ----
function runInjected() {

    pageAction = function () {
        counter += 5;

        document.getElementById("counter").innerText =
            "Counter: " + counter;

        document.getElementById("log").innerText =
            "Injected script modified page logic (+5 per click).";
    };

    document.getElementById("mode").innerText =
        "Mode: INJECTED SCRIPT ACTIVE (logic overridden)";

    document.getElementById("log").innerText =
        "Function overridden. Try clicking again.";
}

// ---- RESET ----
function resetDemo() {
    location.reload();
}

</script>

